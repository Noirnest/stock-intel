# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=stock_intel
POSTGRES_PASSWORD=stock_intel_dev
POSTGRES_DB=stock_intel
DATABASE_URL=postgresql+asyncpg://stock_intel:stock_intel_dev@postgres:5432/stock_intel

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Auth (simple JWT for v1) ────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── App ────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=*

# ─── SEC EDGAR (Compliant access — required fields) ──────────────────────────
# Must identify your application and contact email per SEC fair-access rules.
SEC_USER_AGENT_APP=StockIntelDashboard/1.0
SEC_USER_AGENT_EMAIL=your-email@example.com
SEC_RATE_LIMIT_PER_SECOND=8  # SEC allows ~10/s; we stay conservative

# ─── Provider: News ─────────────────────────────────────────────────────────
# TODO: Replace with a real provider key (e.g., Benzinga, NewsAPI, Polygon.io)
NEWS_PROVIDER=mock         # Options: mock | newsapi | benzinga | polygon
NEWS_API_KEY=

# ─── Provider: Analyst Ratings ──────────────────────────────────────────────
# TODO: Replace with a real provider key (e.g., Benzinga, Refinitiv, TipRanks)
ANALYST_PROVIDER=mock      # Options: mock | benzinga | refinitiv
ANALYST_API_KEY=

# ─── Provider: Market Prices ────────────────────────────────────────────────
# TODO: Replace with a real provider (e.g., Polygon.io, Alpaca, Yahoo Finance)
PRICE_PROVIDER=mock        # Options: mock | polygon | alpaca | yfinance
PRICE_API_KEY=

# ─── Alerts: Webhooks ───────────────────────────────────────────────────────
# TODO: Configure real webhook URLs for alerting
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_EMAIL_FROM=alerts@example.com
SMTP_HOST=localhost
SMTP_PORT=1025

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
